{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "InputTopic": "enrichment-input",
    "ConsumerGroup": "enrichment-service-group",
    "PollTimeoutMs": 1000
  },
  "EnrichmentSchema": {
    "Rules": [
      {
        "SourcePath": "user.id",
        "DestinationPath": "user.profile"
      }
    ]
  },
  "ExternalApi": {
    "BaseUrl": "https://external-api.example.ru",
    "FetchEndpointTemplate": "/api/enrich/{value}",
    "SendEndpoint": "/api/messages/enriched",
    "Timeout": "00:00:10",
    "RetryCount": 3
  }
}
